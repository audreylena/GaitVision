<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/ActivityContainer">

    <!-- Header -->
    <include
        android:id="@+id/header"
        layout="@layout/layout_common_header" />

    <!-- Patient Count (additional element in header area) -->
    <TextView
        android:id="@+id/tvPatientCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:text="0 patients"
        android:textColor="#888888"
        android:textSize="14sp" />

    <!-- Search Bar -->
    <LinearLayout
        android:id="@+id/searchBar"
        style="@style/LayoutMargins"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:orientation="horizontal"
        android:background="@drawable/edit_text_background"
        android:padding="4dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Search by name or patient ID..."
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <ImageButton
            android:id="@+id/btnClearSearch"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Clear search"
            android:visibility="gone"
            app:tint="#888888" />
    </LinearLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:id="@+id/filterChips"
        style="@style/LayoutMargins.HorizontalOnly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/searchBar"
        android:scrollbars="none"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="All"
                android:textSize="12sp"
                android:background="@drawable/chip_selected_background"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <Button
                android:id="@+id/btnFilterRecent"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Recent"
                android:textSize="12sp"
                android:background="@drawable/chip_background"
                android:textColor="#AAAAAA"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <Button
                android:id="@+id/btnFilterWithVideos"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="With Videos"
                android:textSize="12sp"
                android:background="@drawable/chip_background"
                android:textColor="#AAAAAA"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Patient Table Header -->
    <LinearLayout
        android:id="@+id/tableHeader"
        style="@style/LayoutMargins.HorizontalOnly"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_below="@id/filterChips"
        android:orientation="horizontal"
        android:background="#252542"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tvHeaderId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ID"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHeaderFirstName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FIRST"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHeaderLastName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LAST"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHeaderAge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AGE"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvHeaderVideos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="VIDEOS"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <!-- Patient List (RecyclerView) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPatients"
        style="@style/LayoutMargins.Content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tableHeader"
        android:layout_above="@id/fabAddPatient"
        android:background="#1E1E36"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyState"
            style="@style/LayoutMargins.Content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/tableHeader"
            android:layout_above="@id/fabAddPatient"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:alpha="0.5"
                app:tint="#888888" />

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No patients found"
            android:textColor="#888888"
            android:textSize="18sp"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnAddFirstPatient"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="+ Add First Patient"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_primary_background"
            android:layout_marginTop="24dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp" />
    </LinearLayout>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddPatient"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#4CAF50"
        app:tint="#FFFFFF"
        android:contentDescription="Add Patient" />

</RelativeLayout>

