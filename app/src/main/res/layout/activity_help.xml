<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/ActivityContainer"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <include layout="@layout/layout_common_header" />

        <LinearLayout
            style="@style/ContentContainer">

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Getting Started"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome to GaitVision! This application helps you analyze gait patterns and generate comprehensive reports.\n\nKey Features:\n• Patient Management\n• Video Recording and Analysis\n• Comprehensive Gait Reports\n• Historical Data Tracking\n\nTo get started, navigate to the Patient Management section to add a new patient or search for an existing one. Then use the Quick Analysis feature to record or upload a gait video for analysis."
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Recording Tips"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="For best results:\n• Ensure good lighting\n• Position camera at hip height\n• Capture full body walking motion\n• Record at least 3-5 complete gait cycles\n• Keep camera steady"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
