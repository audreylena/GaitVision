<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/footerLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#252542"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingVertical="12dp">

    <!-- Home -->
    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivNavHome"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/baseline_home_24"
            app:tint="@color/text_tertiary" />

        <TextView
            android:id="@+id/tvNavHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Home"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Help -->
    <LinearLayout
        android:id="@+id/navHelp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivNavHelp"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_help_24"
            app:tint="@color/text_tertiary" />

        <TextView
            android:id="@+id/tvNavHelp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Help"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Info -->
    <LinearLayout
        android:id="@+id/navInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivNavInfo"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/baseline_info_24"
            app:tint="@color/text_tertiary" />

        <TextView
            android:id="@+id/tvNavInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Info"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Settings -->
    <LinearLayout
        android:id="@+id/navSettings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivNavSettings"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/baseline_settings_24"
            app:tint="@color/text_tertiary" />

        <TextView
            android:id="@+id/tvNavSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Settings"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
